<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_home"
    >
    <fragment
        android:id="@+id/navigation_home"
        android:name="is.hbv601g.gamecatalog.pages.all_games.AllGamesFragment"
        android:label="All Games"
        tools:layout="@layout/fragment_all_games"
        />

    <fragment
        android:id="@+id/navigation_search_games"
        android:name="is.hbv601g.gamecatalog.pages.search_games.SearchGamesFragment"
        android:label="Search Games"
        tools:layout="@layout/fragment_all_games"
        />

    <fragment
        android:id="@+id/navigation_login"
        android:name="is.hbv601g.gamecatalog.pages.login.LogInFragment"
        android:label="Log In"
        tools:layout="@layout/fragment_login"
        />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="is.hbv601g.gamecatalog.pages.view_own_profile.PersonalProfileFragment"
        android:label="My Profile"
        tools:layout="@layout/fragment_personal_profile" />

    <fragment
        android:id="@+id/navigation_search_users"
        android:name="is.hbv601g.gamecatalog.pages.search_users.SearchUsersFragment"
        android:label="Search Users"
        tools:layout="@layout/fragment_search_users"
        />

    <fragment
        android:id="@+id/navigation_specific_game"
        android:name="is.hbv601g.gamecatalog.pages.specific_game.SpecificGameFragment"
        android:label="Game Details">

        <argument
            android:name="game_id"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/navigation_modify_user"
        android:name="is.hbv601g.gamecatalog.pages.modify_user.ModifyUserFragment"
        android:label="Edit Profile"
        tools:layout="@layout/fragment_modify_user" />

    <fragment
        android:id="@+id/navigation_user_list"
        android:name="is.hbv601g.gamecatalog.pages.user_list.UserListFragment"
        android:label="User List"
        tools:layout="@layout/fragment_user_list">
        <argument
            android:name="user_id"
            app:argType="long" />
        <argument
            android:name="list_type"
            app:argType="string" />
        <!-- Pop any existing OtherUserProfileFragment off the stack before pushing the new one.  The stack is always capped at 4 entries: personal → userlist → profile → userlist -->
        <action
            android:id="@+id/action_user_list_to_other_profile"
            app:destination="@id/navigation_other_user_profile"
            app:popUpTo="@id/navigation_other_user_profile"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/navigation_other_user_profile"
        android:name="is.hbv601g.gamecatalog.pages.other_user_profile.OtherUserProfileFragment"
        android:label="User Profile"
        tools:layout="@layout/fragment_other_user_profile">
        <argument
            android:name="user_id"
            app:argType="long" />
    </fragment>

    <!--OFFLINE FRAGMENTS-->
    <fragment
        android:id="@+id/navigation_offline_all_games"
        android:name="is.hbv601g.gamecatalog.pages.offline_all_games.OfflineAllGamesFragment"
        android:label="All Games Offline"
        tools:layout="@layout/fragment_offline_all_games"
        />

    <fragment
        android:id="@+id/navigation_offline_specific_game"
        android:name="is.hbv601g.gamecatalog.pages.offline_specific_game.OfflineSpecificGameFragment"
        android:label="Game Details Offline">

        <argument
            android:name="game_id"
            app:argType="long" />
    </fragment>

</navigation>